# Ola Maps API Configuration
VITE_OLA_MAP_API_KEY=your_ola_maps_api_key_here

# Neon Database Configuration (Direct URL / Pooled URL)
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Vite Client-side Database Connection (Duplicated with VITE_ prefix to expose to frontend)
VITE_DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Google Tag Manager (GTM) Container ID
VITE_GTM_ID=GTM-XXXXXXX

# Microsoft Clarity Project ID
VITE_CLARITY_ID=your_clarity_project_id_here

# Google Search Console Verification Meta Tag Code
VITE_GOOGLE_VERIFICATION_CODE=your_google_search_console_code_here

# Google Tag Manager (GTM) API Configuration
GTM_API_KEY=your_gtm_api_key_here
VITE_GTM_API_KEY=your_gtm_api_key_here

